from codegen_hooks import wrap_with_banner, noop

@wrap_with_banner(banner="HOOKED")
def hooked_add(a: int, b: int) -> int:
    return a + b

@noop()
def plain_add(a: int, b: int) -> int:
    return a + b

def main() -> int:
    x: int = hooked_add(3, 4)
    y: int = plain_add(10, 20)
    print(x)
    print(y)
    return 0
