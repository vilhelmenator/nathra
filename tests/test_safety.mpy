# Safety checks test — compile with --safe to enable runtime checks.
# Without --safe, all checks are stripped and this runs as normal code.

# ── Division by zero ─────────────────────────────────────────────────────

@test
def test_safe_div_normal() -> void:
    """Normal division works fine under --safe."""
    a: int = 42
    b: int = 7
    test_assert(a / b == 6)
    test_assert(a % b == 0)

@test
def test_safe_div_floor() -> void:
    """Floor division works under --safe."""
    a: int = 17
    b: int = 5
    test_assert(a // b == 3)

# ── Overflow ─────────────────────────────────────────────────────────────

@test
def test_safe_arith_normal() -> void:
    """Normal arithmetic works under --safe."""
    a: int = 100
    b: int = 200
    test_assert(a + b == 300)
    test_assert(b - a == 100)
    test_assert(a * b == 20000)

@test
def test_safe_aug_assign() -> void:
    """Augmented assignment works under --safe."""
    x: int = 10
    x += 5
    test_assert(x == 15)
    x -= 3
    test_assert(x == 12)
    x *= 2
    test_assert(x == 24)
    x /= 6
    test_assert(x == 4)
    x %= 3
    test_assert(x == 1)

# ── Bounds ───────────────────────────────────────────────────────────────

@test
def test_safe_array_bounds() -> void:
    """Array access within bounds works under --safe."""
    arr: array[int, 5] = {10, 20, 30, 40, 50}
    test_assert(arr[0] == 10)
    test_assert(arr[4] == 50)
    arr[2] = 99
    test_assert(arr[2] == 99)

@test
def test_safe_list_bounds() -> void:
    """List access within bounds works under --safe."""
    nums: list[int] = [1, 2, 3]
    test_assert(nums[0] == 1)
    test_assert(nums[2] == 3)
    nums[1] = 42
    test_assert(nums[1] == 42)

# ── Float division is NOT checked (IEEE 754 inf/nan is valid) ────────────

@test
def test_float_div_by_zero() -> void:
    """Float division by zero produces inf, not a crash."""
    a: float = 1.0
    b: float = 0.0
    c: float = a / b
    # IEEE 754: 1.0/0.0 = inf
    test_assert(c > 1000000.0)
