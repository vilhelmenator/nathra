__pycache__/
*.pyc

# Build artifacts
build/

# Generated C files from compilation (not native/generated/ — those are tracked)
tests/*.c
*.c
!native/generated/*.c

# Compiled test binaries (no extension on macOS/Linux)
tests/test_*
!tests/test_*.mpy
test_*
!test_*.mpy

# Benchmark artifacts
bench/bench
bench/*.c
!bench/bench_opts_naive.c
bench/*.h
bench/*.dSYM/

# macOS debug symbol bundles
*.dSYM/

# Shared libraries and binaries
*.so
*.dylib
*.dll
*.exe
hotreload_host
